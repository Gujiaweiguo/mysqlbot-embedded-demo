# 服务器配置
PORT=3100

# 数据库配置
DB_USER=your_db_user
DB_HOST=localhost
DB_NAME=sqlbot
DB_PASSWORD=your_db_password
DB_PORT=5432
STATIC_DIR=../frontend/dist
# 其他配置
NODE_ENV=development

# thxtd datasource configuration (optional, only if using thxtd provider)
THXTD_DB_HOST=your_mysql_host
THXTD_DB_PORT=3306
THXTD_DB_NAME=your_mysql_database
THXTD_DB_USER=your_mysql_user
THXTD_DB_PASSWORD=your_mysql_password
THXTD_DB_SCHEMA=
