# ============================================================
# SQLBot Embedded Demo - 后端环境变量配置
# ============================================================
# 复制本文件为 .env 并填写实际值：
#   cp backend/.env.example backend/.env
# ============================================================

# --------------------------
# 服务器
# --------------------------
# 后端监听端口
PORT=3100

# 运行环境，development 时错误响应包含堆栈信息
NODE_ENV=development

# 前端构建产物的相对路径，生产部署时后端直接托管该目录的静态文件
# 开发模式下不需要此项（前端由 vite dev server 提供）
STATIC_DIR=../frontend/dist

# --------------------------
# PostgreSQL 主数据库（必需）
# --------------------------
# 后端使用此库存储 demo 数据（setting、regions、categories、sales 等表）
# 启动时会自动建表和写入种子数据
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sqlbot
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# --------------------------
# GS SCRM 数据源（可选）
# --------------------------
# 高级小助手的 GS SCRM provider 使用
# 默认连接上面的 PostgreSQL 主库，但指定不同的 database 和 schema
# 如果不需要 GS SCRM provider，可以留空或省略
GS_SCRM_DB_NAME=gs_scrm
GS_SCRM_SCHEMA=public

# --------------------------
# THXTD 数据源（可选）
# --------------------------
# 高级小助手的 thxtd provider 使用
# 连接外部 MySQL 数据库，获取 thxtd 元数据
# 如果不需要 thxtd provider，可以省略整个区块
THXTD_DB_HOST=your_mysql_host
THXTD_DB_PORT=3306
THXTD_DB_NAME=your_mysql_database
THXTD_DB_USER=your_mysql_user
THXTD_DB_PASSWORD=your_mysql_password
THXTD_DB_SCHEMA=
